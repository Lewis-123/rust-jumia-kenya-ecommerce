<section class="hero">
    <div class="hero-content">
        <p class="eyebrow">Kenyan Market Products</p>

        <h1>
            Shop Products Available Across Kenya
        </h1>

        <p>
            Browse quality products, compare prices, and discover items sourced
            from trusted Kenyan online marketplaces.
        </p>

        <div class="hero-actions">
            <a class="btn primary-btn" href="/shop">Shop Now</a>
            <a class="btn secondary-btn" href="/about">Learn More</a>
        </div>
    </div>
</section>

<section class="section">
    <div class="section-heading">
        <p class="eyebrow">Popular Picks</p>

        <h2>
            Popular Products
        </h2>

        <p>
            Browse recently added products available in the Kenyan market.
        </p>
    </div>

    <% if (popularProducts && popularProducts.length > 0) { %>
        <div class="product-grid">
            <% popularProducts.forEach(function(product) { %>
                <article class="product-card">
                    <a class="product-image-link" href="/shop/<%= product.slug %>">
                        <img src="<%= product.imageUrl %>" alt="<%= product.name %>">
                    </a>

                    <div class="product-card-content">
                        <p class="product-category"><%= product.category %></p>

                        <h3>
                            <a href="/shop/<%= product.slug %>">
                                <%= product.name %>
                            </a>
                        </h3>

                        <% if (product.brand) { %>
                            <p class="product-brand-small">
                                <%= product.brand %>
                            </p>
                        <% } %>

                        <p class="product-price">
                            KSh <%= product.price.toLocaleString("en-KE") %>
                        </p>

                        <a class="text-link" href="/shop/<%= product.slug %>">
                            View Product
                        </a>
                    </div>
                </article>
            <% }) %>
        </div>
    <% } else { %>
        <div class="empty-state">
            <h2>No products yet</h2>
            <p>Products will appear here after they are added or imported.</p>
        </div>
    <% } %>
</section>

<section class="section featured-home-section">
    <div class="section-heading">
        <p class="eyebrow">Featured Products</p>

        <h2>
            Featured Deals
        </h2>

        <p>
            Selected products highlighted by the store administrator.
        </p>
    </div>

    <% if (featuredProducts && featuredProducts.length > 0) { %>
        <div class="product-grid">
            <% featuredProducts.forEach(function(product) { %>
                <article class="product-card">
                    <a class="product-image-link" href="/shop/<%= product.slug %>">
                        <img src="<%= product.imageUrl %>" alt="<%= product.name %>">
                    </a>

                    <div class="product-card-content">
                        <p class="product-category"><%= product.category %></p>

                        <h3>
                            <a href="/shop/<%= product.slug %>">
                                <%= product.name %>
                            </a>
                        </h3>

                        <% if (product.brand) { %>
                            <p class="product-brand-small">
                                <%= product.brand %>
                            </p>
                        <% } %>

                        <div class="price-row">
                            <p class="product-price">
                                KSh <%= product.price.toLocaleString("en-KE") %>
                            </p>

                            <% if (product.originalPrice && product.originalPrice > product.price) { %>
                                <p class="card-original-price">
                                    KSh <%= product.originalPrice.toLocaleString("en-KE") %>
                                </p>
                            <% } %>
                        </div>

                        <a class="text-link" href="/shop/<%= product.slug %>">
                            View Product
                        </a>
                    </div>
                </article>
            <% }) %>
        </div>
    <% } else { %>
        <div class="empty-state">
            <h2>No featured products yet</h2>
            <p>Mark products as featured from the admin dashboard.</p>
        </div>
    <% } %>
</section>