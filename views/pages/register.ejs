<section class="page-header">
    <p class="eyebrow">Admin Registration</p>

    <h1>
        Create Admin Account
    </h1>

    <p>
        Register an administrator account to manage the ecommerce product
        catalogue. A verification code will be sent to your email.
    </p>
</section>

<section class="form-section">
    <form class="form-card" action="/register" method="POST">
        <% if (error) { %>
            <div class="alert error-alert">
                <%= error %>
            </div>
        <% } %>

        <label for="fullName">Full Name</label>
        <input
            id="fullName"
            name="fullName"
            type="text"
            value="<%= formData && formData.fullName ? formData.fullName : '' %>"
            required>

        <label for="email">Email Address</label>
        <input
            id="email"
            name="email"
            type="email"
            value="<%= formData && formData.email ? formData.email : '' %>"
            required>

        <label for="password">Password</label>
        <input id="password" name="password" type="password" minlength="8" required>

        <label for="confirmPassword">Confirm Password</label>
        <input
            id="confirmPassword"
            name="confirmPassword"
            type="password"
            minlength="8"
            required>

        <button class="btn primary-btn" type="submit">
            Register and Send Code
        </button>

        <p class="form-note">
            Already have an admin account?
            <a href="/login">Login here</a>
        </p>
    </form>
</section>