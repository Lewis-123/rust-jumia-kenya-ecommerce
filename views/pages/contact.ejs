<section class="page-header">
    <p class="eyebrow">Contact</p>

    <h1>
        Contact Kenya Ecommerce Store
    </h1>

    <p>
        Send us a message about products, support, or business inquiries.
    </p>
</section>

<section class="form-section">
    <form class="form-card" action="/contact" method="POST">
        <% if (successMessage) { %>
            <div class="alert success-alert">
                <%= successMessage %>
            </div>
        <% } %>

        <% if (error) { %>
            <div class="alert error-alert">
                <%= error %>
            </div>
        <% } %>

        <label for="name">Full Name</label>
        <input
            id="name"
            name="name"
            type="text"
            value="<%= formData && formData.name ? formData.name : '' %>"
            required>

        <label for="email">Email Address</label>
        <input
            id="email"
            name="email"
            type="email"
            value="<%= formData && formData.email ? formData.email : '' %>"
            required>

        <label for="message">Message</label>
        <textarea
            id="message"
            name="message"
            rows="6"
            required><%= formData && formData.message ? formData.message : '' %></textarea>

        <button class="btn primary-btn" type="submit">
            Send Message
        </button>
    </form>
</section>