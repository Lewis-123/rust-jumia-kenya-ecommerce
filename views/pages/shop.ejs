<section class="page-header">
    <p class="eyebrow">Shop</p>

    <h1>
        Browse Products
    </h1>

    <p>
        Explore products available in the Kenyan market.
    </p>
</section>

<section class="section shop-section">
    <form class="shop-filter-card" action="/shop" method="GET">
        <div class="filter-group">
            <label for="search">Search Products</label>
            <input
                id="search"
                name="search"
                type="text"
                value="<%= search || '' %>"
                placeholder="Search by name, brand, or keyword">
        </div>

        <div class="filter-group">
            <label for="category">Filter by Category</label>
            <select id="category" name="category">
                <option value="">All Categories</option>

                <% if (categories && categories.length > 0) { %>
                    <% categories.forEach(function(category) { %>
                        <option
                            value="<%= category %>"
                            <%= selectedCategory === category ? "selected" : "" %>>
                            <%= category %>
                        </option>
                    <% }) %>
                <% } %>
            </select>
        </div>

        <div class="filter-actions">
            <button class="btn primary-btn" type="submit">
                Apply Filter
            </button>

            <a class="btn secondary-dark-btn" href="/shop">
                Clear
            </a>
        </div>
    </form>

    <div class="shop-summary">
        <p>
            Showing <strong><%= productCount %></strong>
            <%= productCount === 1 ? "product" : "products" %>
            <% if (search) { %>
                for "<strong><%= search %></strong>"
            <% } %>
            <% if (selectedCategory) { %>
                in <strong><%= selectedCategory %></strong>
            <% } %>
        </p>
    </div>

    <% if (products && products.length > 0) { %>
        <div class="product-grid">
            <% products.forEach(function(product) { %>
                <article class="product-card">
                    <a class="product-image-link" href="/shop/<%= product.slug %>">
                        <img src="<%= product.imageUrl %>" alt="<%= product.name %>">
                    </a>

                    <div class="product-card-content">
                        <p class="product-category"><%= product.category %></p>

                        <h2>
                            <a href="/shop/<%= product.slug %>">
                                <%= product.name %>
                            </a>
                        </h2>

                        <% if (product.brand) { %>
                            <p class="product-brand-small">
                                <%= product.brand %>
                            </p>
                        <% } %>

                        <p class="product-description">
                            <%= product.description.length > 105 ? product.description.substring(0, 105) + "..." : product.description %>
                        </p>

                        <div class="price-row">
                            <p class="product-price">
                                KSh <%= product.price.toLocaleString("en-KE") %>
                            </p>

                            <% if (product.originalPrice && product.originalPrice > product.price) { %>
                                <p class="card-original-price">
                                    KSh <%= product.originalPrice.toLocaleString("en-KE") %>
                                </p>
                            <% } %>
                        </div>

                        <a class="text-link" href="/shop/<%= product.slug %>">
                            View Product
                        </a>
                    </div>
                </article>
            <% }) %>
        </div>
    <% } else { %>
        <div class="empty-state">
            <h2>No matching products found</h2>

            <p>
                Try clearing the filters or searching for another product.
            </p>

            <a class="btn primary-btn" href="/shop">
                View All Products
            </a>
        </div>
    <% } %>
</section>