<section class="page-header">
    <p class="eyebrow">Admin Dashboard</p>

    <h1>
        Welcome, <%= currentAdmin && currentAdmin.name ? currentAdmin.name : "Admin" %>
    </h1>

    <p>
        Manage products, imports, and ecommerce catalogue information from this
        secure dashboard.
    </p>
</section>

<section class="section">
    <% if (successMessage) { %>
        <div class="alert success-alert page-alert">
            <%= successMessage %>
        </div>
    <% } %>

    <% if (errorMessage) { %>
        <div class="alert error-alert page-alert">
            <%= errorMessage %>
        </div>
    <% } %>

    <div class="admin-grid">
        <article class="admin-stat-card">
            <p>Total Products</p>
            <h2><%= totalProducts %></h2>
        </article>

        <article class="admin-stat-card">
            <p>Active Products</p>
            <h2><%= activeProducts %></h2>
        </article>

        <article class="admin-stat-card">
            <p>Hidden Products</p>
            <h2><%= hiddenProducts %></h2>
        </article>

        <article class="admin-stat-card">
            <p>Featured Products</p>
            <h2><%= featuredProducts %></h2>
        </article>

        <article class="admin-stat-card">
            <p>Imported Products</p>
            <h2><%= importedProducts %></h2>
        </article>

        <article class="admin-stat-card">
            <p>Categories</p>
            <h2><%= categoryCount %></h2>
        </article>
    </div>

    <div class="admin-actions">
        <a class="btn primary-btn" href="/admin/products">
            Manage Products
        </a>

        <a class="btn secondary-dark-btn" href="/admin/products/new">
            Add Product
        </a>

        <a class="btn secondary-dark-btn" href="/admin/products/import">
            Import from Jumia
        </a>

        <form action="/logout" method="POST">
            <button class="btn danger-btn" type="submit">
                Logout
            </button>
        </form>
    </div>
</section>

<section class="section admin-recent-section">
    <div class="section-heading compact-heading">
        <p class="eyebrow">Recent Products</p>

        <h2>
            Latest Catalogue Updates
        </h2>

        <p>
            These are the most recently added or imported products.
        </p>
    </div>

    <% if (recentProducts && recentProducts.length > 0) { %>
        <div class="table-wrapper">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>Image</th>
                        <th>Product</th>
                        <th>Category</th>
                        <th>Price</th>
                        <th>Source</th>
                    </tr>
                </thead>

                <tbody>
                    <% recentProducts.forEach(function(product) { %>
                        <tr>
                            <td>
                                <img class="table-image"
                                     src="<%= product.imageUrl %>"
                                     alt="<%= product.name %>">
                            </td>

                            <td>
                                <strong><%= product.name %></strong>
                                <br>
                                <small><%= product.brand || "No brand" %></small>
                            </td>

                            <td><%= product.category %></td>

                            <td>
                                KSh <%= product.price.toLocaleString("en-KE") %>
                            </td>

                            <td>
                                <span class="badge <%= product.source === 'apify-jumia' ? 'feature-badge' : 'success-badge' %>">
                                    <%= product.source === "apify-jumia" ? "Jumia Import" : "Manual" %>
                                </span>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    <% } else { %>
        <div class="empty-state">
            <h2>No recent products</h2>
            <p>Add or import products to populate this dashboard section.</p>
        </div>
    <% } %>
</section>