<section class="page-header">
    <p class="eyebrow">Product Management</p>

    <h1>
        Manage Products
    </h1>

    <p>
        View, edit, delete, search, filter, and add ecommerce products from the
        secured admin backend.
    </p>
</section>

<section class="section">
    <% if (successMessage) { %>
        <div class="alert success-alert page-alert">
            <%= successMessage %>
        </div>
    <% } %>

    <% if (errorMessage) { %>
        <div class="alert error-alert page-alert">
            <%= errorMessage %>
        </div>
    <% } %>

    <div class="admin-toolbar">
        <a class="btn primary-btn" href="/admin/products/new">
            Add Product
        </a>

        <a class="btn secondary-dark-btn" href="/admin/products/import">
            Import from Jumia
        </a>

        <a class="btn secondary-dark-btn" href="/admin/dashboard">
            Back to Dashboard
        </a>
    </div>

    <form class="admin-filter-card" action="/admin/products" method="GET">
        <div class="filter-group">
            <label for="search">Search Products</label>
            <input id="search"
                   name="search"
                   type="text"
                   value="<%= search || '' %>"
                   placeholder="Search by name, brand, category">
        </div>

        <div class="filter-group">
            <label for="source">Source</label>
            <select id="source" name="source">
                <option value="">All Sources</option>
                <option value="manual" <%= source === "manual" ? "selected" : "" %>>
                    Manual
                </option>
                <option value="apify-jumia" <%= source === "apify-jumia" ? "selected" : "" %>>
                    Jumia Import
                </option>
            </select>
        </div>

        <div class="filter-group">
            <label for="status">Status</label>
            <select id="status" name="status">
                <option value="">All Statuses</option>
                <option value="active" <%= status === "active" ? "selected" : "" %>>
                    Active
                </option>
                <option value="hidden" <%= status === "hidden" ? "selected" : "" %>>
                    Hidden
                </option>
                <option value="featured" <%= status === "featured" ? "selected" : "" %>>
                    Featured
                </option>
            </select>
        </div>

        <div class="filter-actions">
            <button class="btn primary-btn" type="submit">
                Apply
            </button>

            <a class="btn secondary-dark-btn" href="/admin/products">
                Clear
            </a>
        </div>
    </form>

    <div class="shop-summary">
        <p>
            Showing <strong><%= productCount %></strong>
            <%= productCount === 1 ? "product" : "products" %>.
        </p>
    </div>

    <% if (products && products.length > 0) { %>
        <div class="table-wrapper">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>Image</th>
                        <th>Product</th>
                        <th>Category</th>
                        <th>Price</th>
                        <th>Stock</th>
                        <th>Status</th>
                        <th>Source</th>
                        <th>Actions</th>
                    </tr>
                </thead>

                <tbody>
                    <% products.forEach(function(product) { %>
                        <tr>
                            <td>
                                <img class="table-image"
                                     src="<%= product.imageUrl %>"
                                     alt="<%= product.name %>">
                            </td>

                            <td>
                                <strong><%= product.name %></strong>
                                <br>
                                <small><%= product.brand || "No brand" %></small>
                            </td>

                            <td><%= product.category %></td>

                            <td>
                                KSh <%= product.price.toLocaleString("en-KE") %>
                            </td>

                            <td><%= product.stock %></td>

                            <td>
                                <% if (product.isActive) { %>
                                    <span class="badge success-badge">Active</span>
                                <% } else { %>
                                    <span class="badge muted-badge">Hidden</span>
                                <% } %>

                                <% if (product.isFeatured) { %>
                                    <span class="badge feature-badge">Featured</span>
                                <% } %>
                            </td>

                            <td>
                                <span class="badge <%= product.source === 'apify-jumia' ? 'feature-badge' : 'success-badge' %>">
                                    <%= product.source === "apify-jumia" ? "Jumia Import" : "Manual" %>
                                </span>
                            </td>

                            <td>
                                <div class="table-actions">
                                    <a class="small-btn view-btn"
                                       href="/shop/<%= product.slug %>"
                                       target="_blank">
                                        View
                                    </a>

                                    <a class="small-btn edit-btn"
                                       href="/admin/products/<%= product._id %>/edit">
                                        Edit
                                    </a>

                                    <form action="/admin/products/<%= product._id %>/delete"
                                          method="POST"
                                          onsubmit="return confirm('Delete this product?');">
                                        <button class="small-btn delete-btn" type="submit">
                                            Delete
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    <% } else { %>
        <div class="empty-state">
            <h2>No products found</h2>

            <p>
                Try clearing the filters, adding a product manually, or importing
                products from Jumia Kenya.
            </p>
        </div>
    <% } %>
</section>