<section class="page-header">
    <p class="eyebrow">Add Product</p>

    <h1>
        Create New Product
    </h1>

    <p>
        Add a product manually to the ecommerce catalogue.
    </p>
</section>

<section class="form-section">
    <form class="form-card wide-form"
          action="/admin/products"
          method="POST"
          enctype="multipart/form-data">

        <% if (error) { %>
            <div class="alert error-alert">
                <%= error %>
            </div>
        <% } %>

        <label for="name">Product Name</label>
        <input id="name" name="name" type="text" required>

        <label for="description">Description</label>
        <textarea id="description" name="description" rows="6" required></textarea>

        <label for="price">Price in KSh</label>
        <input id="price" name="price" type="number" min="1" required>

        <label for="originalPrice">Original Price in KSh</label>
        <input id="originalPrice" name="originalPrice" type="number" min="1">

        <label for="category">Category</label>
        <input id="category" name="category" type="text" required>

        <label for="brand">Brand</label>
        <input id="brand" name="brand" type="text">

        <label for="stock">Stock</label>
        <input id="stock" name="stock" type="number" min="0" value="0" required>

        <label for="productUrl">Source Product URL</label>
        <input id="productUrl" name="productUrl" type="url">

        <label for="image">Product Image</label>
        <input id="image" name="image" type="file" accept="image/png,image/jpeg,image/webp" required>

        <div class="checkbox-row">
            <label>
                <input name="isActive" type="checkbox" checked>
                Active product
            </label>

            <label>
                <input name="isFeatured" type="checkbox">
                Featured product
            </label>
        </div>

        <div class="form-actions">
            <button class="btn primary-btn" type="submit">
                Save Product
            </button>

            <a class="btn secondary-dark-btn" href="/admin/products">
                Cancel
            </a>
        </div>
    </form>
</section>