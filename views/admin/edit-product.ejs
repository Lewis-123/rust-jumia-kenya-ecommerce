<section class="page-header">
    <p class="eyebrow">Edit Product</p>

    <h1>
        Update Product
    </h1>

    <p>
        Edit product information, visibility, price, stock, and image.
    </p>
</section>

<section class="form-section">
    <form class="form-card wide-form"
          action="/admin/products/<%= product._id %>"
          method="POST"
          enctype="multipart/form-data">

        <% if (error) { %>
            <div class="alert error-alert">
                <%= error %>
            </div>
        <% } %>

        <label for="name">Product Name</label>
        <input id="name" name="name" type="text" value="<%= product.name %>" required>

        <label for="description">Description</label>
        <textarea id="description" name="description" rows="6" required><%= product.description %></textarea>

        <label for="price">Price in KSh</label>
        <input id="price" name="price" type="number" min="1" value="<%= product.price %>" required>

        <label for="originalPrice">Original Price in KSh</label>
        <input id="originalPrice"
               name="originalPrice"
               type="number"
               min="1"
               value="<%= product.originalPrice || '' %>">

        <label for="category">Category</label>
        <input id="category" name="category" type="text" value="<%= product.category %>" required>

        <label for="brand">Brand</label>
        <input id="brand" name="brand" type="text" value="<%= product.brand || '' %>">

        <label for="stock">Stock</label>
        <input id="stock" name="stock" type="number" min="0" value="<%= product.stock %>" required>

        <label for="productUrl">Source Product URL</label>
        <input id="productUrl"
               name="productUrl"
               type="url"
               value="<%= product.productUrl || '' %>">

        <div class="current-image">
            <p>Current Image</p>
            <img src="<%= product.imageUrl %>" alt="<%= product.name %>">
        </div>

        <label for="image">Replace Product Image</label>
        <input id="image" name="image" type="file" accept="image/png,image/jpeg,image/webp">

        <div class="checkbox-row">
            <label>
                <input name="isActive"
                       type="checkbox"
                       <%= product.isActive ? "checked" : "" %>>
                Active product
            </label>

            <label>
                <input name="isFeatured"
                       type="checkbox"
                       <%= product.isFeatured ? "checked" : "" %>>
                Featured product
            </label>
        </div>

        <div class="form-actions">
            <button class="btn primary-btn" type="submit">
                Update Product
            </button>

            <a class="btn secondary-dark-btn" href="/admin/products">
                Cancel
            </a>
        </div>
    </form>
</section>